      {"text": "// Phase 2: RTA"},
      {"text": "reachable \u2190 {main}"},
      {"text": "for each r in reachable:"},
      {"text": "  for each call in r:"},
      {"text": "    filter targets by instantiated"},
      {"text": "// Phase 3: VTA"},
      {"text": "for each call in reachable:"},
      {"text": "  refine by PTA(receiver)"},
      {"text": "return callgraph"}
