  "pseudocode": {
    "title": "ANDERSEN-PTA(P)",
    "lines": [
      {"text": "C ← ExtractConstraints(P)"},
      {"text": "for each addr(v,loc) ∈ C:"},
      {"text": "  pts(v) ← pts(v) ∪ {loc}"},
      {"text": "  add v to worklist"},
      {"text": "while worklist ≠ ∅:"},
      {"text": "  v ← pop(worklist)"},
      {"text": "  for each copy(v,w) ∈ C:"},
      {"text": "    if pts(w) ⊅ pts(v):"},
      {"text": "      pts(w) ← pts(w) ∪ pts(v)"},
      {"text": "      add w to worklist"},
      {"text": "return pts"}
    ]
  },
