      {"text": "for each var v: I(v) ← ⊥"},
      {"text": "worklist ← {entry}"},
      {"text": "while worklist ≠ ∅:"},
      {"text": "  b ← pop(worklist)"},
      {"text": "  old ← state(b)"},
      {"text": "  new ← ⊔ {transfer(p) | p ∈ pred(b)}"},
      {"text": "  if b is loop header:"},
      {"text": "    new ← widen(old, new)"},
      {"text": "  if new ≠ old:"},
      {"text": "    state(b) ← new"},
      {"text": "    add successors to worklist"},
      {"text": "NARROW(CFG)"},
      {"text": "return state"}
    ]
  },
