    { "from": "github-pages", "to": "site", "type": "deploys" },

    { "from": "selectors", "to": "findings", "type": "data", "label": "produces" },
    { "from": "program-db", "to": "property-graph", "type": "data", "label": "exports" },
    { "from": "pta", "to": "pta-export", "type": "data", "label": "exports" }
  ]
}
